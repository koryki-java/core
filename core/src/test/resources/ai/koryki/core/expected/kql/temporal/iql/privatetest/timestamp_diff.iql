// TIMESTAMP - TIMESTAMP -> the exact elapsed span as fixed seconds (canonical koryki notation under
// StableFormat; HH:MM:SS for a business format). The span never rolls into calendar days, so over
// 24h stays clock hours (50:00:00, not "2 days 02:00:00"). Subtracting the same instant in different
// encodings (INSTANT / Unix epoch seconds / Java epoch millis) reconciles to zero. Each side reduces
// to epoch-seconds per its encoding, so the semantics are uniform across all dialects.

SELECT
 check_temporal c
  OUT minus(c.ts_diff_intraday, c.ts_diff_base) intraday 1
  OUT minus(c.ts_diff_multiday, c.ts_diff_base) multiday 2
  OUT minus(c.ts_diff_base, c.ts_diff_intraday) negative 3
  OUT minus(c.ts_diff_base, c.ts_diff_base) zero 4
  OUT minus(c.timestamp_zoned, c.timestamp_unix_epoche) instant_minus_unix 5
  OUT minus(c.timestamp_zoned, c.timestamp_java_epoche) instant_minus_java 6
  OUT minus(c.timestamp_unix_epoche, c.timestamp_java_epoche) unix_minus_java 7
  OUT minus(c.timestamp_timestamp, minus(c.timestamp_timestamp, 3h20min30s)) self_3h20min30s 8
  FILTER
    c.nr = 1