@startebnf
' border and background
skinparam legendBorderColor transparent
skinparam legendBackgroundColor white

'title expression

expression =
 "(", expression, ")"
| expression, ("*" | "/"), expression
| expression, ("+" | "+"), expression
| date_literal
| field
| function
| "INT"
| "NUMBER"
| "STRING"
| "NULL"
| "(", select, ")"
;

@endebnf
